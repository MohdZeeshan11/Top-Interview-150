class Solution {
    public int[] twoSum(int[] nums, int target) {
        int[] ans = new int[2];
        Map<Integer, Integer> map = new HashMap<>();

        for(int i = 0; i < nums.length; i++){
            int check = target - nums[i];
            if(map.containsKey(check)){
                int index = map.get(check);
                ans[0] = i;
                ans[1] = index;
                break;
            }
            map.put(nums[i], i);

        }
        return ans;
    }
}