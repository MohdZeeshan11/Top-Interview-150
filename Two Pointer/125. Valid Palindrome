class Solution {
    public boolean isPalindrome(String s) {
        s = s.toLowerCase();
        

        String result = "";
        for(int i = 0;i < s.length(); i++){
            char ch = s.charAt(i);
            int ascii = (int)ch;
            if((ascii >= 48 && ascii <= 57) || (ascii >= 97 && ascii <= 122)  || (ascii >= 65 && ascii <= 90) ){
                result = result + ch;
            }
        }

        if(result.length() == 0 || result.length() == 1) return true;

        int left = 0;
        int right = 0;

        Stack<Character> st = new Stack<>();
        for(int i = 0; i < result.length(); i++){
            st.push(result.charAt(i));
        }
        for(int i = 0; i < result.length(); i++){
            if(result.charAt(i) != st.peek()){
                return false;
            }
            st.pop();
        }

        return true;
    }
}
