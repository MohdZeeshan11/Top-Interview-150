class Solution {
    public boolean validPalindrome(String s) {
        
        int left = 0;
        int right = s.length()-1;

        while(right > left){

            if(s.charAt(left) != s.charAt(right)){

                if(isPalindrome(left, right-1, s)){
                    return true;
                }else if(isPalindrome(left+1, right, s)){
                    return true;
                }
                return false;
            }
            right--;
            left++;
        }

        return true;
    }


    public boolean isPalindrome(int left, int right, String s){

        while(right > left){
            if(s.charAt(left) != s.charAt(right)){
                return false;
            }
            right--;
            left++;
        }

        return true;
    }
}