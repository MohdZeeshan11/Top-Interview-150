        // }

        // for(int i = 0; i < nums.length; i++){
        //     nums[i] = ans[i];
        // }
        if (nums.length == 1 && nums[0] != val)
            return nums.length;
        int i = 0;
        int j = nums.length-1;
        int count = 0;
        while (i <= j) {
            if (nums[i] == val) {
                if(nums[i] != nums[j]){
                    nums[i] = nums[j];
                }
                j--;
            }else{
                i++;
            }
        }

        return i;
    }
}